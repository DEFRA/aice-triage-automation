# Copy to .env and fill in. .env is git-ignored — never commit real values.

# Which scoring engine to use: `stub` (offline, no network, no cost) or
# `bedrock` (calls a real hosted AI model). Defaults to `stub`.
SCORING_ENGINE=stub

# The AWS region to call Amazon Bedrock in. eu-west-2 is London.
BEDROCK_REGION=

# Model identifiers. Leave empty until you know which models this account can
# actually invoke in this region — that is a later story.
BEDROCK_SCORE_MODEL_ID=
BEDROCK_CLASSIFY_MODEL_ID=

# The Amazon Bedrock API key (a bearer token). Read directly by the AWS SDK.
# This is a SECRET. It is not declared in src/config.js.
# The AWS SDK reads it directly from the environment at runtime.
AWS_BEARER_TOKEN_BEDROCK=

# A local, git-ignored directory of example triage submissions.
SUBMISSIONS_DIR=
